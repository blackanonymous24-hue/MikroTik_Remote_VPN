# --- Développement local ---
DATABASE_URL="postgresql://nanotech:nanotech_dev@localhost:5432/mikrotik_vpn?schema=public"
JWT_SECRET="dev-only-change-me-min-32-chars-long!!"

NEXT_PUBLIC_APP_DOMAIN="nanotechvpn.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_VPN_HOST="vpn.nanotechvpn.com"
NEXT_PUBLIC_VPN_WG_ENDPOINT="vpn.nanotechvpn.com:51820"

# mock = dev sans VPS | local/ssh = production
PROVISION_MODE="mock"
VPN_PROVISION_PATH="/opt/nanotech-vpn"

# Production L2TP (obligatoire si PROVISION_MODE=local)
# L2TP_IPSEC_SECRET="votre-secret-ipsec"

# Mode ssh (app et VPN sur serveurs séparés)
# VPN_SSH_HOST="vpn.nanotechvpn.com"
# VPN_SSH_PORT="22"
# VPN_SSH_USER="root"
# VPN_SSH_KEY_PATH="/path/to/key"

# Seed (dev)
# SEED_ADMIN_EMAIL="HS"
# SEED_ADMIN_PASSWORD="root"
# SEED_DEMO_DEVICES=1

# --- Production VPS : voir deploy/env.production.example ou deploy/env.production.cohabitation.example ---
