# Production VPS dédié — /var/www/nanotech-vpn/.env

NODE_ENV=production
PORT=3000

DATABASE_URL="postgresql://mikrotik_vpn:MOT_DE_PASSE_FORT@localhost:5432/mikrotik_vpn?schema=public"
JWT_SECRET="generer-avec-openssl-rand-base64-32-minimum-32-caracteres"

NEXT_PUBLIC_APP_DOMAIN="nanotechvpn.com"
NEXT_PUBLIC_APP_URL="https://nanotechvpn.com"
NEXT_PUBLIC_VPN_HOST="vpn.nanotechvpn.com"
NEXT_PUBLIC_VPN_WG_ENDPOINT="vpn.nanotechvpn.com:51820"

# Obligatoire en production — scripts sur le même VPS
PROVISION_MODE=local
VPN_PROVISION_PATH=/opt/nanotech-vpn

# Secret IPsec L2TP (identique pour tous les clients MikroTik sur ce serveur)
L2TP_IPSEC_SECRET="generer-secret-ipsec-fort"

# Si app et VPN sur des serveurs différents :
# PROVISION_MODE=ssh
# VPN_SSH_HOST=vpn.nanotechvpn.com
# VPN_SSH_USER=root
# VPN_SSH_PORT=22
# VPN_SSH_KEY_PATH=/home/nanotech/.ssh/id_ed25519

# Seed initial (une seule fois) : RUN_SEED=1 lors du setup
# SEED_ADMIN_EMAIL=admin@votredomaine.com
# SEED_ADMIN_PASSWORD=mot-de-passe-fort
# SEED_DEMO_DEVICES=0
